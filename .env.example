# Frontend Environment Variables (Vite)
VITE_API_BASE_URL=http://localhost:4000
VITE_SUPABASE_URL=https://udnpbqtvbnepicwyubnm.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Hedera network configuration: "testnet" or "mainnet"
VITE_HEDERA_NETWORK=testnet

# Hedera Mirror Node Endpoints
VITE_TESTNET_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
VITE_MAINNET_MIRROR_NODE_URL=https://mainnet-public.mirrornode.hedera.com

# HashPack / HashConnect Configuration
# Project ID from https://cloud.walletconnect.com/ (required by HashConnect v3)
VITE_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id
