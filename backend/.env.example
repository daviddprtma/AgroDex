# Hedera Configuration
HEDERA_OPERATOR_ID=YOUR_HEDERA_OPERATOR_ID
HEDERA_OPERATOR_KEY=YOUR_HEDERA_OPERATOR_KEY
HEDERA_TOPIC_ID=YOUR_HEDERA_TOPIC_ID
# you can use https://testnet.mirrornode.hedera.com (for testnet) or https://mainnet-public.mirrornode.hedera.com (for mainnet)
MIRROR_NODE_URL=YOUR_MIRROR_NODE_URL

# Supabase Configuration
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Gemini AI Configuration
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_TIMEOUT_MS=6000

# Anthropic AI Configuration
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# Server Configuration
PORT=4000
NODE_ENV=development